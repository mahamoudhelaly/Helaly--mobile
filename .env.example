# رابط الاتصال بقاعدة بيانات PostgreSQL
# الصيغة: postgresql://username:password@host:port/database_name
#
# لو بتستخدم Neon, Supabase, أو Railway هيعطوك الرابط ده جاهز من لوحة التحكم
DATABASE_URL=postgresql://user:password@localhost:5432/helaly_app

# نص عشوائي طويل وسري يستخدم لتوقيع وتشفير الـ JWT Tokens
# لازم يكون نص طويل وغير متوقع (مش "secret123")
JWT_SECRET=غير_هذا_النص_بنص_عشوائي_طويل_جدا

# المنفذ اللي السيرفر هيشتغل عليه (اختياري، افتراضي 3000)
PORT=3000
